# Copy to terraform.tfvars and fill in real values, or pass via -var / TF_VAR_*.
# terraform.tfvars is gitignored - never commit real secrets.

aws_region  = "ap-south-1"
admin_cidr  = "203.0.113.5/32" # replace with your own IP for SSH access

db_password = "replace-with-a-strong-password"
jwt_secret  = "replace-with-a-random-32-byte-secret"

app_repo_url    = "https://github.com/your-org/cloudbank.git"
app_repo_branch = "main"

# Leave domain_name empty to skip Route 53 and reach the app via the ALB DNS name.
domain_name    = ""
app_subdomain  = "app"

key_pair_name = null
